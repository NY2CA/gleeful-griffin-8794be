# Copy to .env.local for local dev. In production, set these on Netlify at
# Site settings → Environment variables.

# ── Required ────────────────────────────────────────────────────────────────
# Any random 32+ char string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Resend API key (https://resend.com). Free tier covers 3k emails/mo.
# After signing up, verify a sending domain (e.g. mail.resciaproperties.com)
# and create a sender identity that matches RESEND_FROM below.
RESEND_API_KEY=

# The "From" header on outgoing email. The domain MUST be verified in Resend.
# Format: "Rescia Properties <no-reply@mail.resciaproperties.com>"
RESEND_FROM=

# Base URL of the deployed site — used to build the absolute links we put in
# password-reset emails AND in Stripe Checkout success/cancel URLs. No trailing
# slash. Example: https://members.resciaproperties.com
# If omitted, we fall back to the request origin — fine for dev, can be wrong
# behind some proxies in prod.
APP_URL=

# ── Stripe billing ──────────────────────────────────────────────────────────
# Server-side secret key. Starts with sk_test_ in test mode, sk_live_ in live.
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Signing secret for the webhook endpoint. Starts with whsec_.
# Get it from Stripe → Developers → Webhooks → your endpoint → "Signing secret".
# (Locally, `stripe listen --forward-to localhost:8888/api/billing/webhook`
# prints a different whsec_… — use that one for local dev.)
STRIPE_WEBHOOK_SECRET=

# The three Stripe Price ids for our plans. Create them in Stripe → Products.
#   STRIPE_PRICE_ANNUAL    — recurring, yearly
#   STRIPE_PRICE_MONTHLY   — recurring, monthly
#   STRIPE_PRICE_LIFETIME  — one-off (mode=payment)
# Each price id looks like: price_1Nxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ANNUAL=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_LIFETIME=

# ── Optional ────────────────────────────────────────────────────────────────
# Only needed if the frontend runs on a different origin than the functions.
# Leave blank for the default (same-origin on Netlify).
NEXT_PUBLIC_API_BASE=
